{
  "name": "rulesgen",
  "version": "0.1.0",
  "description": "Generate AI coding assistant rules files from your codebase",
  "type": "module",
  "bin": {
    "rulesgen": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": ["dist/", "README.md"],
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": ["claude", "cursor", "copilot", "ai", "rules", "CLAUDE.md", "cursorrules"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist/"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "cosmiconfig": "^9.0.0",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
